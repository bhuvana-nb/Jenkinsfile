pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/your-username/your-repo.git'
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t my-python-app .'
            }
        }

        stage('Deploy') {
            steps {
                sh 'docker run -d -p 80:5000 my-python-app'
            }
        }
    }
}
